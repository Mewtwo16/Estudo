@startuml
actor Usuario

boundary "Tela de Login" as Tela
control "LoginController" as Controller
control "AutenticacaoService" as Service

Usuario -> Tela : informarCredenciais(login, senha)
Tela -> Controller : realizarLogin(login, senha)
Controller -> Service : validarCredenciais(login, senha)
Service --> Controller : autenticado
Controller -> Tela : exibirSucesso()
Tela -> Usuario : loginRealizado()

@enduml
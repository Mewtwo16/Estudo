@startuml
actor Cliente

boundary "Tela de Pedido" as Tela
control "PedidoController" as Controller
control "PedidoService" as Service
entity "Pedido" as Pedido
entity "Estoque" as Estoque

Cliente -> Tela : iniciarPedido()
Tela -> Controller : criarPedido()
Controller -> Service : criarPedido()
Service -> Pedido : <<create>>
Service --> Controller : pedidoCriado

loop Para cada item selecionado
    Cliente -> Tela : adicionarItem(produto, quantidade)
    Tela -> Controller : adicionarItem(produto, quantidade)
    Controller -> Service : verificarEstoque(produto, quantidade)
    Service -> Estoque : consultarQuantidade(produto)
    Estoque --> Service : quantidadeDisponivel
    Service --> Controller : estoqueOk
    Controller -> Service : adicionarItemAoPedido(produto, quantidade)
    Service -> Pedido : adicionarItem(produto, quantidade)
end

Controller -> Tela : exibirResumoPedido()
Tela -> Cliente : mostrarItensDoPedido()

@enduml